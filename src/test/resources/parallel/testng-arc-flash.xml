<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="480000" name="Arc Flash (34 tests)" verbose="0">
    <!--
    ============================================================
    ARC FLASH MODULE — v1.49 data-readiness tracker (changelog 111)
    ============================================================
      NOT feature-flag gated: runs on every tenant, including while
      eng-lib is off. Mirrors web /arc-flash "Arc Flash Readiness"
      (NFPA 70E completeness). Oracles are cross-element arithmetic
      invariants (Completed+Remaining==Total, card % == round(X/Y),
      overall == weighted average) — they cannot pass tautologically.

      1. ArcFlash_Test (13)          — Site-tab quick action →
         "Arc Flash Analysis" dashboard: ring, stats, 3 metric cards,
         breakdown switching, bucket expansion, reentry determinism.
      2. ArcFlashPunchlist_Test (6)  — Assets/Connections tab
         "Show/Hide AF Punchlist" badge toggles; session-room
         "Arc Flash" overlay filter + long-press "Collect AF Data"
         (session tests precondition-skip when no active WO fixture).
      3. AssetEngineerFlagCanary_Test (1) — eng-lib flag ⇄ Settings
         card UI consistency canary; NOT gated so it runs in both
         tenant modes and screams on flag/UI drift.
    ============================================================
    -->
    <listeners>
        <listener class-name="com.egalvanic.listeners.GlobalTestTimeout"/>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="Arc Flash - Analysis Dashboard">
        <classes>
            <class name="com.egalvanic.tests.ArcFlash_Test"/>
        </classes>
    </test>
    <test name="Arc Flash - Punchlist + Session">
        <classes>
            <class name="com.egalvanic.tests.ArcFlashPunchlist_Test"/>
        </classes>
    </test>
    <test name="Arc Flash - Breakdown Deep Laws">
        <classes>
            <class name="com.egalvanic.tests.ArcFlashBreakdown_Test"/>
        </classes>
    </test>
    <test name="Arc Flash - EngLib Flag Canary">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerFlagCanary_Test"/>
        </classes>
    </test>

</suite>
