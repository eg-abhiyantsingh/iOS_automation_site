<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="480000" name="Site Visit / Work Orders - Phase 1 (39 tests)" verbose="0">
    <!--
    ============================================================
    SITE VISIT PHASE 1 — 39 tests (TC_JOB_001 - TC_JOB_039)
    ============================================================
      - Dashboard: No Active Job card display and tap
      - Work Orders screen: header, Start New button, Available section
      - Work order entries: name, date, badge, indicator, counts
      - Activate Job: button display, activation, ACTIVE badge, single-active rule
      - Session Details: header, Active Session badge, stats, information, QR action
      - Session Tabs: bottom tabs (Details, Locations, Tasks, Issues, Files)
      - Session Issues: tab badge, summary, Manage Issues, linked list, + button
      - Link Issues: screen UI, search, checkboxes, already-linked checkmarks
      - Link Issues interactions: empty circle, select/deselect, Update state
      - Link Issues save/cancel: Update saves, Cancel discards, search filtering
      - My Session filter: tab display and count verification
    ============================================================
    -->

    <listeners>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="Site Visit Phase 1 - Work Orders Screen UI">
        <classes>
            <class name="com.egalvanic.tests.SiteVisit_phase1"/>
        </classes>
    </test>

</suite>
