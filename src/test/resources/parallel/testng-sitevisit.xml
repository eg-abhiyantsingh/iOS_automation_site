<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="480000" name="Site Visit / Work Orders - All Phases" verbose="0">
    <!--
    ============================================================
    SITE VISIT — ALL PHASES (TC_JOB_001 - TC_JOB_344)
    ============================================================
      Phase 1: Dashboard, Work Orders, Activate Job, Session Details,
               Session Tabs, Issues, Link Issues, My Session
      Phase 2: Session Details deep, Tasks, Photo Walkthrough setup,
               Gallery, Add Photos, Quick Count, Link Existing Asset
      Phase 3: Photo Walkthrough: Camera, Done, Remove, Classify Asset,
               OCPD, Issues grouped, Files tab
    ============================================================
    -->

    <listeners>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="Site Visit Phase 1 - Work Orders Screen UI">
        <classes>
            <class name="com.egalvanic.tests.SiteVisit_phase1"/>
        </classes>
    </test>

    <test name="Site Visit Phase 2 - Session Details and Tasks">
        <classes>
            <class name="com.egalvanic.tests.SiteVisit_phase2"/>
        </classes>
    </test>

    <test name="Site Visit Phase 3 - Photo Walkthrough and Files">
        <classes>
            <class name="com.egalvanic.tests.SiteVisit_phase3"/>
        </classes>
    </test>

</suite>
