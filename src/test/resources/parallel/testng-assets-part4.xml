<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="420000" name="Asset Tests - Part 4 of 6 (109 tests)" verbose="0">
    <!--
    ============================================================
    ASSET PART 4 — 109 tests
    ============================================================
      Native (97 tests):
      - OCP_EAD  (13 tests) — Over-Current Protective Device: no core attributes,
                               save without them, no validation indicators, issues section
      - PB       (14 tests) — Panelboard: core attributes, required fields toggle,
                               numeric/dropdown validation, size, voltage, save/cancel
      - TC_PDU   (15 tests) — Power Distribution Unit: required fields, ampere rating,
                               catalog number, mfg, serial, size, voltage, cancel
      - TC_RELAY (14 tests) — Relay: manufacturer, model, relay type, serial, notes,
                               save/cancel, persistence, scroll behavior
      - TC_SWB   (18 tests) — Switchboard: required fields, ampere rating, config,
                               fault withstand, mains type, mfg, serial, size, voltage
      - TC_TRF   (23 tests) — Transformer: required fields, BIL, class, frequency,
                               KVA rating, % impedance, primary/secondary amps & voltage,
                               winding configuration, temperature rise

      Moved from Part 3 (12 tests):
      - OTHER_EAD_CA_02-13: Other Asset Class core attribute tests
    ============================================================
    -->

    <listeners>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>

    <!-- Native Part 4 tests (97 tests) — all methods -->
    <test name="Asset Phase 4 - OCP, Panelboard, PDU, Relay, Switchboard, Transformer">
        <classes>
            <class name="com.egalvanic.tests.Asset_Phase4_Test"/>
        </classes>
    </test>

    <!-- Moved from Part 3: 12 OTHER_EAD_CA tests -->
    <test name="Asset Phase 4 - Other Asset Class Tests (from P3)">
        <classes>
            <class name="com.egalvanic.tests.Asset_Phase3_Test">
                <methods>
                    <include name="OTHER_EAD_CA_02_verifyCoreAttributesFieldsList"/>
                    <include name="OTHER_EAD_CA_03_verifyNoRequiredFieldsIndicator"/>
                    <include name="OTHER_EAD_CA_04_verifyRequiredFieldsToggleNotVisible"/>
                    <include name="OTHER_EAD_CA_05_editModelField"/>
                    <include name="OTHER_EAD_CA_06_editNotesField"/>
                    <include name="OTHER_EAD_CA_07_editNPVoltsField"/>
                    <include name="OTHER_EAD_CA_08_editSerialNumberField"/>
                    <include name="OTHER_EAD_CA_09_saveWithAllCoreAttributesEmpty"/>
                    <include name="OTHER_EAD_CA_10_saveWithPartialCoreAttributes"/>
                    <include name="OTHER_EAD_CA_11_saveWithAllCoreAttributesFilled"/>
                    <include name="OTHER_EAD_CA_12_verifyPlaceholderText"/>
                    <include name="OTHER_EAD_CA_13_cancelEditWithoutSaving"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
