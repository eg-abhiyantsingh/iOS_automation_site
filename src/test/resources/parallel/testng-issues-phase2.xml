<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="420000" name="Issues Tests - Phase 2 (50 tests)" verbose="0">
    <!--
    ============================================================
    ISSUES PHASE 2 — 50 tests (TC_ISS_130 - TC_ISS_179)
    ============================================================
      - Repair Needed class fields
      - Thermal Anomaly: severity, criteria, temperature fields
      - Current Draw / Voltage Drop tables
      - Required fields toggle
      - Ultrasonic Anomaly fields

    MOVED TO PHASE 3 (10 tests — OSHA subcategory verifications, 420s+ each):
      TC_ISS_120-129 (10 OSHA subcategory option tests)
    ============================================================
    -->

    <listeners>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="Issues Phase 2 - Thermal, Severity, Temperature, Ultrasonic">
        <classes>
            <class name="com.egalvanic.tests.Issue_Phase2_Test">
                <methods>
                    <!-- Exclude 10 slow OSHA tests (420s+ each) — moved to Phase 3 -->
                    <exclude name="TC_ISS_120_verifyOSHASubcategoryDropdownOptions"/>
                    <exclude name="TC_ISS_121_verifyClearanceInsufficientAccessOption"/>
                    <exclude name="TC_ISS_122_verifyEnclosureBrokenLockingMechanismOption"/>
                    <exclude name="TC_ISS_123_verifyEnclosureDamagedOption"/>
                    <exclude name="TC_ISS_124_verifyEnclosureShouldBeWaterproofOption"/>
                    <exclude name="TC_ISS_125_verifyEquipmentFreeOfHazardsOption"/>
                    <exclude name="TC_ISS_126_verifyGroundingPermanentContinuousOption"/>
                    <exclude name="TC_ISS_127_verifyLightingInadequateOption"/>
                    <exclude name="TC_ISS_128_verifyMarkingLabelsInadequateOption"/>
                    <exclude name="TC_ISS_129_verifyMountingShouldBeSecureOption"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
