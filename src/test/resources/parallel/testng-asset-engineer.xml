<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="480000" name="Asset Engineer (166 tests)" verbose="0">
    <!--
    ============================================================
    ASSET ENGINEER MODULE — v1.49 asset_engineer library (105 cases)
    ============================================================
      6 classes, ordered:
        1. AssetEngineer_Test (16)            — core journeys; TC_ENG_003
           is the library-download state gate for everything after.
        2. AssetEngineerClassMatrix_Test (16) — per-class Engineering
           block contract in cancelled Add-Asset drafts.
        3. AssetEngineerInputs_Test (20)      — int/double input-filter
           matrices on draft fields.
        4. AssetEngineerMenus_Test (7)        — enum menu semantics
           (Panelboard mains options, None-clears, Create-Main sheet,
           ATS parity, fuse subtype sheet).
        5. AssetEngineerCustomSheet_Test (35) — ZP-2267 custom equipment
           sheet: identity gating, 15 Function subtypes, I²t/Dial
           suffixes, transformer/cable/busway sections + defaults.
        6. AssetEngineerSettings_Test (6)     — card granular + library
           persistence across app relaunch + re-download-replaces.
        7. AssetEngineerMatching_Test (5)     — ⚠️ QUARANTINE: LIVE
           matching probes on small DOMs. MUST STAY LAST — rendering
           match results on the transformer DETAILS screen wedges WDA
           (documented v1.49 app defect); keeping these last stops a
           wedge from cascading.
      All classes pin DriverManager.setNoReset(true): NO_RESET=false
      would wipe the downloaded library cache on every driver build.
    ============================================================
    -->
    <listeners>
        <listener class-name="com.egalvanic.listeners.GlobalTestTimeout"/>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="Asset Engineer - Core">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineer_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Class Matrix">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerClassMatrix_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Input Filters">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerInputs_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Enum Menus">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerMenus_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Custom Equipment Sheet">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerCustomSheet_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Settings Granular">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerSettings_Test"/>
        </classes>
    </test>
    <!-- Gap-roadmap classes (changelog 112, G1-G13): written from app-source
         ground truth while eng-lib is off; first live run happens when the
         flag returns (the FlagCanary in the arc-flash suite is the tripwire). -->
    <test name="Asset Engineer - Trip Configurator">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerTripConfig_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Ground Fault">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerGroundFault_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Custom Save + Edit">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerCustomSave_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Field + Voltage Pickers">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerFieldPickers_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Match Panel Search + Pagination">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerMatchPanel_Test"/>
        </classes>
    </test>
    <test name="Asset Engineer - Live Matching (quarantined last)">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineerMatching_Test"/>
        </classes>
    </test>

</suite>
