<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="480000" name="Demo Smoke (23 proven-stable tests)" verbose="0">
    <!--
    DEMO-READY SMOKE SUITE (changelogs 122 + 123).
    Selection rule: a test earns a slot ONLY if it (a) covers a critical user
    journey, (b) has a CLEAN record across the recent failed-suite history
    (failed-suites/*.xml + git history of same-day overwrites), and (c) runs
    fast (<90s). Target: green in <15 min on every build, 100% stable. If a
    test here flakes twice, it LEAVES the suite (stability is the product).

    Changelog 123 applied the rule to the Equipment Library block itself:
    - OUT: TC_ENG_130 (flag-drift CANARY - deliberately ungated, fails loudly
      when the eng-lib flag drifts; it did on 07-09 + 07-13. Right behavior,
      wrong suite - it stays in the daily monitor/module suites).
    - OUT: TC_ENG_004 (needs downloaded-library state; failed on the drift day).
    - Library-match tests are EXCLUDED BY DESIGN here: the SKM library download
      is 2-10 min on a fresh container vs the 360s GlobalTestTimeout default -
      unstable by construction. That journey lives in testng-asset-engineer.xml.
    - IN: 3 no-library Engineering tests, validated green on a real fresh
      simulator (run 29313356507): TC_ENG_100/101 (settings card + dialog
      contract), TC_ENG_040 (Add-Asset modes + class picker).
    -->
    <listeners>
        <listener class-name="com.egalvanic.listeners.GlobalTestTimeout"/>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="Smoke - Auth + Site">
        <classes>
            <class name="com.egalvanic.tests.AuthenticationTest">
                <methods>
                    <include name="TC01_verifyWelcomeScreenUILoads"/>
                    <include name="TC25_verifyValidLoginNavigatesToDashboard"/>
                </methods>
            </class>
            <class name="com.egalvanic.tests.SiteSelectionTest">
                <methods>
                    <include name="TC_SS_017_verifySitesButtonOnDashboard"/>
                    <include name="TC_SS_018_verifySitesButtonOpensSelectSite"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Smoke - Equipment Library">
        <classes>
            <!-- Light first: settings surface, no draft, no download needed (card asserts in ANY state). -->
            <class name="com.egalvanic.tests.AssetEngineerSettings_Test">
                <methods>
                    <include name="TC_ENG_100_cardNameCompositionContract"/>
                    <include name="TC_ENG_101_loadDialogReopensStably"/>
                </methods>
            </class>
            <!-- Add-Asset entry plumbing: Quick/Detailed modes + class picker; cancelled, no library. -->
            <class name="com.egalvanic.tests.AssetEngineer_Test">
                <methods><include name="TC_ENG_040_verifyAddAssetModesAndClassPicker"/></methods>
            </class>
            <!-- TC_ENG_070 (Mains Type picker) was trialled here and LEFT per the flake-twice rule:
                 debut run 29313356507 (2026-07-14) hung twice in the Panelboard draft fixture on the
                 fresh container (360s ThreadTimeout, then wedged the Appium session). Its clean module-
                 suite history didn't transfer - composition effect. It stays in testng-asset-engineer.xml. -->
        </classes>
    </test>
    <test name="Smoke - Arc Flash Readiness">
        <classes>
            <class name="com.egalvanic.tests.ArcFlash_Test">
                <methods>
                    <include name="TC_AF_003_readinessRingPercentInRange"/>
                    <include name="TC_AF_004_statLineArithmetic"/>
                    <include name="TC_AF_005_threeMetricCardsPresent"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Smoke - Assets">
        <classes>
            <class name="com.egalvanic.tests.Asset_Phase1_Test">
                <methods>
                    <include name="ATS_EAD_01_openEditAssetDetailsScreen"/>
                    <include name="ATS_EAD_02_verifyCoreAttributesSection"/>
                    <include name="ATS_ECR_37_verifyAssetAppearsInAssetList"/>
                </methods>
            </class>
            <class name="com.egalvanic.tests.Asset_Phase6_Test">
                <methods><include name="COM_01_verifyConditionOfMaintenanceOptionsDisplayed"/></methods>
            </class>
        </classes>
    </test>
    <test name="Smoke - Issues">
        <classes>
            <class name="com.egalvanic.tests.Issue_Phase1_Test">
                <methods>
                    <include name="TC_ISS_001_verifyIssuesScreenHeaderElements"/>
                    <include name="TC_ISS_003_verifyFilterTabsDisplayed"/>
                    <include name="TC_ISS_021_verifyAddButtonOpensNewIssue"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Smoke - Connections">
        <classes>
            <class name="com.egalvanic.tests.Connections_Test">
                <methods>
                    <include name="TC_CONN_002_verifyConnectionsScreenHeader"/>
                    <include name="TC_CONN_014_verifyAddButtonOpensNewConnectionScreen"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Smoke - Work Orders + ZP323">
        <classes>
            <class name="com.egalvanic.tests.SiteVisit_phase1">
                <methods>
                    <include name="TC_JOB_002_verifyTapNoActiveJobOpensWorkOrdersScreen"/>
                    <include name="TC_JOB_003_verifyWorkOrdersScreenHeader"/>
                    <include name="TC_JOB_004_verifyStartNewWorkOrderButton"/>
                </methods>
            </class>
            <class name="com.egalvanic.tests.ZP323_NewFeatures_Test">
                <methods><include name="TC_ZP323_15_01_verifyScheduleSectionPresent"/></methods>
            </class>
        </classes>
    </test>
</suite>
