<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="480000" name="Authentication Test Suite" verbose="0">
    
    <!-- Custom Listener for Clean Console Output -->
    <listeners>
        <listener class-name="com.egalvanic.listeners.GlobalTestTimeout"/>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>
    
    <test name="Authentication Tests">
        <classes>
            <class name="com.egalvanic.tests.AuthenticationTest">

            </class>
            <!-- Adversarial input / real-user edge cases (hard assertions, no pass-anyway) -->
            <class name="com.egalvanic.tests.Security_EdgeCase_Test"/>
        </classes>
    </test>
</suite>
