<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="420000" name="Asset Tests - Part 5 of 6 (100 tests)" verbose="0">
    <!--
    ============================================================
    ASSET PART 5 — 100 tests
    ============================================================
      - TC_UPS     (15 tests) — UPS: required fields, ampere rating, catalog, mfg,
                                 model, notes, size, voltage, cancel, persistence
      - TC_UTL      (9 tests) — Utility: meter number, starting voltage, save/cancel,
                                 scroll behavior
      - TC_VFD      (8 tests) — Variable Frequency Drive: no core attributes,
                                 required fields toggle, save, cancel, persistence
      - TC_ATS_ST  (13 tests) — ATS Subtypes: auto transfer switch low/high,
                                 transfer switch low/high, switching between values
      - TC_BUS_ST  (11 tests) — Busway Subtypes: busway low/high, change multiple
                                 times, save/cancel, persistence
      - TC_CAP_ST   (6 tests) — Capacitor Subtypes: none option, save, persistence
      - TC_CB_ST   (14 tests) — Circuit Breaker Subtypes: insulated case, molded case
                                 (<=250A / >250A), power CB, medium voltage, persistence
      - TC_DEF      (9 tests) — Default Asset Class: default selection, subtype field,
                                 no core attributes, save, cancel
      - TC_DS_ST    (4 tests) — Disconnect Switch Subtypes (12 moved to Part 6)
      - TC_FUSE_ST  (11 tests) — Fuse Subtypes (kept)

    MOVED TO PART 6 (12 tests — tail DS_ST + all FUSE_ST subtypes):
      TC_DS_ST_16, TC_FUSE_ST_01-11
    ============================================================
    -->

    <listeners>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>

    <test name="Asset Phase 5 - UPS, Utility, VFD, Subtypes (ATS, Busway, Capacitor, CB, Default, DS)">
        <classes>
            <class name="com.egalvanic.tests.Asset_Phase5_Test">
                <methods>
                    <!-- Exclude 12 tests — moved to Part 6 for load balancing -->
                    <exclude name="TC_DS_ST_16_verifySubtypeDoesNotAffectOtherFields"/>
                    <exclude name="TC_FUSE_ST_01_verifyAssetSubtypeFieldVisibility"/>
                    <exclude name="TC_FUSE_ST_02_verifyDefaultAssetSubtypeValue"/>
                    <exclude name="TC_FUSE_ST_03_verifyAssetSubtypeDropdownOptions"/>
                    <exclude name="TC_FUSE_ST_04_selectFuse1000VOrLess"/>
                    <exclude name="TC_FUSE_ST_05_selectFuseOver1000V"/>
                    <exclude name="TC_FUSE_ST_06_switchBetweenFuseSubtypes"/>
                    <exclude name="TC_FUSE_ST_07_saveFuseAssetWithSubtypeSelected"/>
                    <exclude name="TC_FUSE_ST_08_verifySubtypePersistenceAfterSave"/>
                    <exclude name="TC_FUSE_ST_09_saveFuseAssetWithSubtypeNone"/>
                    <exclude name="TC_FUSE_ST_10_verifyCancelBehaviorAfterSubtypeChange"/>
                    <exclude name="TC_FUSE_ST_11_verifySubtypeDoesNotAffectOtherFields"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
