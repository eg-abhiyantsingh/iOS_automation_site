<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite time-out="480000" name="Connections Test Suite" verbose="0">
    
    <!-- Custom Listener for Clean Console Output -->
    <listeners>
        <listener class-name="com.egalvanic.listeners.GlobalTestTimeout"/>
        <listener class-name="com.egalvanic.listeners.ConsoleProgressListener"/>
    </listeners>
    
    <!-- Re-enabled 2026-06-11: Connection tab is back in the v1.43 app
         (was hidden in v1.36; disabled 2026-05-28). TC_CONN_004 and
         TC_CONN_059 verified passing locally against v1.43. -->
    <test name="Connections Tests" enabled="true">
        <classes>
            <class name="com.egalvanic.tests.Connections_Test"/>
        </classes>
    </test>
</suite>
