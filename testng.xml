    <!--
        Asset Engineer module (changelog 107): v1.49 SKM equipment library
        (Settings download card + encrypted v2 transport) and the Engineering
        section on Asset Details (per-class blocks, match panel, bound card,
        custom equipment sheet). Library download is the in-class state gate.
    -->
    <test name="Asset Engineering Tests">
        <classes>
            <class name="com.egalvanic.tests.AssetEngineer_Test"/>
            <class name="com.egalvanic.tests.AssetEngineerClassMatrix_Test"/>
            <class name="com.egalvanic.tests.AssetEngineerInputs_Test"/>
            <class name="com.egalvanic.tests.AssetEngineerMenus_Test"/>
            <class name="com.egalvanic.tests.AssetEngineerCustomSheet_Test"/>
            <class name="com.egalvanic.tests.AssetEngineerSettings_Test"/>
            <!-- Matching stays LAST: live match probes can wedge WDA (v1.49 defect) -->
            <class name="com.egalvanic.tests.AssetEngineerMatching_Test"/>
        </classes>
    </test>

    <!--
        Cross-module data-integrity E2E (changelog 078): chains Assets+Issues to
        catch orphaned-reference / ghost-record bugs that per-module tests miss.
        Environmental gaps skip cleanly (read-only data, no API egress).
    -->
    <test name="E2E Cross-Module Integrity Tests">
        <classes>
            <class name="com.egalvanic.tests.E2E_CrossModuleIntegrity_Test"/>
        </classes>
    </test>
</suite>
