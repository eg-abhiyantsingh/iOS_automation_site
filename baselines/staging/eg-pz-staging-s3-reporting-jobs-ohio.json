{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowAuthenticatedUploads",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::165183897698:user/cicd-devops"
      },
      "Action": [
        "s3:PutObject",
        "s3:PutObjectAcl"
      ],
      "Resource": "arn:aws:s3:::eg-pz-staging-s3-reporting-jobs-ohio/*"
    },
    {
      "Sid": "DenyInsecureTransport",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::eg-pz-staging-s3-reporting-jobs-ohio",
        "arn:aws:s3:::eg-pz-staging-s3-reporting-jobs-ohio/*"
      ],
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    },
    {
      "Sid": "AllowCICDDevopsAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::165183897698:user/cicd-devops"
      },
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::eg-pz-staging-s3-reporting-jobs-ohio",
        "arn:aws:s3:::eg-pz-staging-s3-reporting-jobs-ohio/*"
      ]
    }
  ]
}
